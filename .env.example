# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=123456789
ADMIN_CHAT_ID=123456789
TELEGRAM_HTTP_VERSION=1.1
TELEGRAM_FORCE_IPV4=true
TELEGRAM_CONNECT_TIMEOUT=20
TELEGRAM_READ_TIMEOUT=30

# Scheduling
AUTO_MODE=true
INTERVAL_DAYS=2
SENDS_PER_DAY=1
RANDOM_TIME_MODE=false
SEND_TIME=20:00
APP_TIMEZONE=Africa/Cairo

# Messages
QUOTE_API_URL=https://www.affirmations.dev/

# Message tone tags:
# Choose one or more comma-separated tags.
# Supported tags:
# romantic, gentle, encouraging, supportive, reassuring,
# affectionate, cozy, playful, proud, calm, sweet
# Also accepted:
# lovely -> sweet, soft -> gentle, warm -> cozy,
# comforting -> reassuring, cute -> playful, caring -> supportive
MESSAGE_TONE_TAGS=romantic,gentle,encouraging

# Images
# Use one or more groups separated by | .
# Inside each group, use comma-separated keywords.
IMAGE_API_URL_TEMPLATE=https://loremflickr.com/{width}/{height}/{tags}?lock={seed}
IMAGE_TAGS=flowers,roses,petals/all|sunset,sky,clouds/all|ocean,beach,waves/all|forest,mountains,nature/all
IMAGE_WIDTH=1200
IMAGE_HEIGHT=1600

# App
LOG_LEVEL=INFO
