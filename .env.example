# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=123456789
# Optional: comma-separated list for broadcasting to multiple chats.
# When TELEGRAM_CHAT_IDS is set, it is used instead of TELEGRAM_CHAT_ID.
TELEGRAM_CHAT_IDS=123456789,987654321
ADMIN_CHAT_ID=123456789
TELEGRAM_HTTP_VERSION=1.1
TELEGRAM_FORCE_IPV4=true
TELEGRAM_CONNECT_TIMEOUT=20
TELEGRAM_READ_TIMEOUT=30

# Scheduling
AUTO_MODE=true
INTERVAL_DAYS=2
SENDS_PER_DAY=1
RANDOM_TIME_MODE=false
SEND_TIME=20:00
APP_TIMEZONE=Africa/Cairo

# Messages
QUOTE_PROVIDER=cohere
QUOTE_THEME=stoicism, discipline, resilience, self-control, inner peace
COHERE_API_KEY=your_cohere_api_key
COHERE_MODEL=command-r-08-2024
COHERE_API_URL=https://api.cohere.com/v2/chat
QUOTE_API_URL=https://www.affirmations.dev/

# Message tone tags:
# Choose one or more comma-separated tags.
# Supported tags:
# romantic, gentle, encouraging, supportive, reassuring,
# affectionate, cozy, playful, proud, calm, sweet
# Also accepted:
# lovely -> sweet, soft -> gentle, warm -> cozy,
# comforting -> reassuring, cute -> playful, caring -> supportive
MESSAGE_TONE_TAGS=stoic,disciplined,calm,intense

# Images
# Use one or more groups separated by | .
# Inside each group, use comma-separated keywords.
IMAGE_API_URL_TEMPLATE=https://loremflickr.com/{width}/{height}/{tags}?lock={seed}
IMAGE_TAGS=greek statue,marble bust,black and white,stoic/all|ancient sculpture,monochrome,philosopher,statue/all|anime panel,manga,black and white,warrior/all|badass anime,monochrome,panel,intense/all
IMAGE_WIDTH=1200
IMAGE_HEIGHT=1600

# App
LOG_LEVEL=INFO
